# Copy to `.env` and adjust values. Do not commit `.env`.

# SQLite database file path, relative to the project root (same as `prisma migrate`)
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Local dev: Next.js listens on this port (must match NEXTAUTH_URL)
PORT=3080

# App URL (no trailing slash). Same host/port you use in the browser.
NEXTAUTH_URL="http://localhost:3080"

# Docker only: port published on your machine (container still uses 3000 inside).
# Compose defaults to 3080; override if needed, e.g. APP_PORT=3000
# APP_PORT=3080

# OpenRouter API keys are not configured here. Enter your key in the Studio UI
# (stored in the browser / session for requests); API routes read it from request headers.

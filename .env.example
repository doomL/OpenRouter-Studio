# Copy to `.env` and adjust values. Do not commit `.env`.

# SQLite database file path, relative to the project root (same as `prisma migrate`)
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# App URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# OpenRouter API keys are not configured here. Enter your key in the Studio UI
# (stored in the browser / session for requests); API routes read it from request headers.
